<style>
  .footer {
    background: linear-gradient(180deg, #1a2744 0%, var(--ht-navy) 100%);
    color: rgba(255,255,255,.8);
    padding: 80px 0 40px;
  }
  .footer-grid {
    display: grid; grid-template-columns: 1.5fr 1fr 1fr 1fr;
    gap: 48px; margin-bottom: 48px;
  }
  .footer-logo { height: 36px; width: auto; margin-bottom: 16px; }
  .footer-brand p { font-size: .9rem; line-height: 1.7; color: rgba(255,255,255,.6); }

  .footer-col h4 {
    font-family: var(--ht-font-display); font-size: .9rem;
    font-weight: 600; color: #fff; margin-bottom: 16px;
    text-transform: uppercase; letter-spacing: .08em;
  }
  .footer-col ul { list-style: none; padding: 0; }
  .footer-col li { margin-bottom: 10px; }
  .footer-col a {
    font-size: .9rem; color: rgba(255,255,255,.6);
    transition: color .2s ease;
  }
  .footer-col a:hover { color: #fff; }

  .footer-bottom {
    border-top: 1px solid rgba(255,255,255,.1);
    padding-top: 24px; text-align: center;
  }
  .footer-bottom p { font-size: .85rem; color: rgba(255,255,255,.4); margin: 0; }
  .footer-legal { display: flex; gap: 16px; justify-content: center; margin-top: 8px; }
  .footer-legal a { font-size: .8rem; color: rgba(255,255,255,.35); transition: color .2s ease; }
  .footer-legal a:hover { color: rgba(255,255,255,.7); }

  @media (max-width: 768px) {
    .footer-grid { grid-template-columns: 1fr 1fr; gap: 32px; }
  }
  @media (max-width: 480px) {
    .footer-grid { grid-template-columns: 1fr; }
  }
</style>
