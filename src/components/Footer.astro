          <li><a href="/#benefits">Manage Notices Efficiently</a></li>
        </ul>
      </div>

      <div class="footer-col">
        <h4>Features</h4>
        <ul>
          <li><a href="/#features">Secure Network</a></li>
          <li><a href="/#features">Notice Tracking</a></li>
          <li><a href="/#features">Returns Management</a></li>
