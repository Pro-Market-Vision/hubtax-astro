---
const benefits = [
  {
    icon: '/images/Tax-Calendar.webp',
    title: 'Manage All Tax Obligations',
    desc: 'Our dynamic tax calendar keeps you ahead of every deadline, ensuring you never miss a payment or filing date. AI-powered alerts notify you before critical dates approach.',
  },
  {
    icon: '/images/Create-Organization-img.webp',
    title: 'Create Organization',
    desc: 'Build a structured, easily navigable system for all your tax-related documents and tasks. AI automatically categorizes and tags incoming documents for instant retrieval.',
  },
  {
    icon: '/images/Organized-1.webp',
    title: 'Keep Everything Organized',
    desc: 'From documents to passwords, keep all your sensitive tax information organized and accessible in one secure location with AI-powered search and smart filing.',
  },
  {
    icon: '/images/Manage-Notice.webp',
    title: 'Manage Notices Efficiently',
    desc: 'Track and manage all tax notices with ease. Our AI scans incoming notices via OCR, extracts key data, and surfaces recommended actions so you\'re always prepared.',
  },
];
---

<section class="section section-alt fade-up" id="benefits">
  <div class="container">
    <div class="benefits-header">
      <span class="label">Why HubTax</span>
      <h2>Take control of your<br/><span class="gradient-text">tax workflow</span></h2>
      <p class="benefits-sub">Powered by AI to save you time on every task — from OCR document scanning to intelligent knowledge base research.</p>
    </div>
    <div class="benefits-grid">
      {benefits.map(b => (
        <div class="benefit-card">
          <div class="benefit-icon">
            <img src={b.icon} alt={b.title} loading="lazy" />
          </div>
          <h3>{b.title}</h3>
          <p>{b.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .benefits-header { text-align: center; margin-bottom: 48px; }
  .benefits-sub { max-width: 560px; margin: 12px auto 0; font-size: .95rem; color: var(--ht-text); line-height: 1.7; }

  .benefits-grid {
    display: grid; grid-template-columns: repeat(2, 1fr);
    gap: 24px;
  }

  .benefit-card {
    padding: 32px; border-radius: 16px;
    background: var(--ht-white);
    border: 1px solid rgba(0,0,0,.06);
    transition: all .35s cubic-bezier(.4,0,.2,1);
  }
  .benefit-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 16px 48px rgba(4,107,210,.1);
    border-color: rgba(4,107,210,.12);
  }

  .benefit-icon {
    width: 56px; height: 56px; border-radius: 14px;
    background: rgba(4,107,210,.06);
    display: flex; align-items: center; justify-content: center;
    margin-bottom: 20px; overflow: hidden;
  }
  .benefit-icon img { width: 36px; height: 36px; object-fit: contain; }

  .benefit-card h3 {
    font-size: 1.1rem; font-weight: 700; color: var(--ht-navy);
    margin-bottom: 10px; letter-spacing: -.01em;
  }
  .benefit-card p {
    font-size: .9rem; line-height: 1.7; color: var(--ht-text);
  }

  @media (max-width: 768px) {
    .benefits-grid { grid-template-columns: 1fr; }
  }
</style>
