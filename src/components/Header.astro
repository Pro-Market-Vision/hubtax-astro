---
const navLinks = [
  { label: 'Home', href: '/' },
  { label: 'About Us', href: '/about' },
  { label: 'Why HubTax', href: '/why-hubtax' },
  { label: 'Pricing', href: '/pricing' },
  { label: 'Blog', href: '/blog' },
];
---

<header class="nav-wrap" id="navWrap">
  <div class="nav-inner">
    <nav class="nav">
      <a href="/" class="nav-logo">
        <img src="/images/hubtax-logo.png" alt="HubTax" />
      </a>

      <ul class="nav-links">
        {navLinks.map(link => (
          <li>
            <a href={link.href}>{link.label}</a>
          </li>
        ))}
      </ul>

      <div class="nav-actions">
        <a href="https://app.hubtax.io" class="nav-login">Login</a>
        <a href="/book-a-demo" class="btn btn-primary nav-cta">Book a Demo</a>
      </div>

      <div class="mobile-actions">
        <a href="/book-a-demo" class="mobile-trial-btn">Book a Demo</a>
        <button class="hamburger" id="hamburger" aria-label="Toggle menu">
          <span></span><span></span><span></span>
        </button>
      </div>
    </nav>
  </div>
</header>

<div class="overlay" id="overlay"></div>
<div class="mobile-menu" id="mobileMenu">
  <ul class="mobile-links">
    {navLinks.map(link => (
      <li>
        <a href={link.href}>{link.label}</a>
      </li>
    ))}
    <li><a href="https://app.hubtax.io">Login</a></li>
  </ul>
  <a href="/book-a-demo" class="mobile-cta">Book a Demo</a>
  <a href="https://app.hubtax.io/register" class="mobile-signup-cta">Sign Up Free</a>
</div>

<!-- AI-Powered Banner -->
<div class="ai-bar" id="aiBar">
  <div class="container ai-bar-inner">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4M12 8h.01"/></svg>
    <span>Now powered by AI — OCR scanning, smart research & automated workflows</span>
    <a href="/book-a-demo" class="ai-bar-link">See how it works &rarr;</a>
    <button class="ai-bar-dismiss" id="aiBarClose" aria-label="Dismiss">
      <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M11 3L3 11M3 3l8 8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
    </button>
  </div>
</div>

<script>
  const hamburger = document.getElementById('hamburger');
  const overlay = document.getElementById('overlay');
  const mobileMenu = document.getElementById('mobileMenu');

  function toggleMenu() {
    hamburger?.classList.toggle('active');
    overlay?.classList.toggle('active');
    mobileMenu?.classList.toggle('active');
  }

  hamburger?.addEventListener('click', toggleMenu);
  overlay?.addEventListener('click', toggleMenu);
  mobileMenu?.querySelectorAll('a').forEach(a => a.addEventListener('click', toggleMenu));

  // Scroll shadow on navbar
  const navWrap = document.getElementById('navWrap');
  function updateNav() {
    if (window.scrollY > 10) {
      navWrap?.classList.add('scrolled');
    } else {
      navWrap?.classList.remove('scrolled');
    }
  }
  window.addEventListener('scroll', updateNav, { passive: true });
  updateNav();

  // AI bar dismiss
  const aiBar = document.getElementById('aiBar');
  const aiBarClose = document.getElementById('aiBarClose');

  if (localStorage.getItem('ht-ai-bar-dismissed')) {
    aiBar?.classList.add('dismissed');
  }

  aiBarClose?.addEventListener('click', () => {
    aiBar?.classList.add('dismissed');
    localStorage.setItem('ht-ai-bar-dismissed', '1');
  });
</script>

<style>
  .nav-wrap {
    position: fixed; top: 0; left: 0; right: 0; width: 100%;
    z-index: 9990;
    background: rgba(255,255,255,.85);
    backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px);
    border-bottom: 1px solid rgba(0,0,0,.06);
    transition: background .3s ease, box-shadow .3s ease, border-color .3s ease;
  }
  .nav-wrap.scrolled {
    background: rgba(255,255,255,.95);
    box-shadow: 0 1px 24px rgba(15,23,42,.08);
    border-bottom-color: rgba(0,0,0,.08);
  }
  .nav-inner {
    max-width: 1280px; margin: 0 auto;
    padding: 0 32px;
  }
  .nav {
    display: flex; align-items: center; justify-content: space-between;
    height: 64px;
  }
  .nav-logo { display: flex; align-items: center; flex-shrink: 0; }
  .nav-logo img { height: 32px; width: auto; }

  .nav-links {
    display: flex; align-items: center; gap: 2px;
    list-style: none; margin: 0; padding: 0;
  }
  .nav-links > li > a {
    font-family: var(--ht-font-display);
    font-size: .87rem; font-weight: 500; color: var(--ht-text);
    padding: 8px 16px; border-radius: 8px;
    transition: all .2s ease; white-space: nowrap;
    display: inline-flex; align-items: center; gap: 5px;
  }
  .nav-links > li > a:hover { background: rgba(4,107,210,.07); color: var(--ht-navy); }

  .nav-actions { display: flex; align-items: center; gap: 8px; }
  .nav-login {
    font-family: var(--ht-font-display);
    font-size: .87rem; font-weight: 500; color: var(--ht-text);
    padding: 8px 18px; border-radius: 8px; transition: all .2s ease;
  }
  .nav-login:hover { color: var(--ht-navy); background: rgba(4,107,210,.07); }
  .nav-cta {
    font-size: .85rem !important; padding: 9px 24px !important;
    border-radius: 10px !important;
  }

  .mobile-actions {
    display: none; align-items: center; gap: 10px;
  }
  .mobile-trial-btn {
    font-family: var(--ht-font-display);
    font-size: .78rem; font-weight: 600; color: #fff;
    padding: 7px 14px; border-radius: 8px;
    border: none;
    background: var(--ht-blue);
    transition: all .2s ease; white-space: nowrap;
    box-shadow: 0 2px 8px rgba(4,107,210,.25);
  }
  .mobile-trial-btn:hover { background: var(--ht-blue-dark); }
  .hamburger {
    display: flex; flex-direction: column; gap: 5px;
    background: none; border: none; cursor: pointer;
    padding: 8px; z-index: 9992;
  }
  .hamburger span {
    display: block; width: 22px; height: 2px;
    background: var(--ht-navy); border-radius: 2px; transition: all .3s ease;
  }
  .hamburger.active span:nth-child(1) { transform: rotate(45deg) translate(5px, 5px); }
  .hamburger.active span:nth-child(2) { opacity: 0; }
  .hamburger.active span:nth-child(3) { transform: rotate(-45deg) translate(5px, -5px); }

  :global(.overlay) {
    display: none; position: fixed; inset: 0;
    background: rgba(15,23,42,.4); backdrop-filter: blur(12px);
    z-index: 9991; opacity: 0; transition: opacity .3s ease;
  }
  :global(.overlay.active) { display: block; opacity: 1; }

  :global(.mobile-menu) {
    display: none; position: fixed; top: 0; right: 0; bottom: 0;
    width: min(340px, 85vw); background: #fff; z-index: 9992;
    padding: 80px 24px 32px;
    transform: translateX(100%); transition: transform .35s cubic-bezier(.4,0,.2,1);
    overflow-y: auto; box-shadow: -8px 0 40px rgba(15,23,42,.1);
  }
  :global(.mobile-menu.active) { display: block; transform: translateX(0); }

  :global(.mobile-links) {
    list-style: none; margin: 0; padding: 0;
    display: flex; flex-direction: column; gap: 2px;
  }
  :global(.mobile-links > li > a) {
    display: flex; align-items: center; justify-content: space-between;
    width: 100%; font-family: var(--ht-font-display);
    font-size: 1.05rem; font-weight: 500; color: var(--ht-navy);
    padding: 14px 16px; border-radius: 12px; transition: all .2s ease;
  }
  :global(.mobile-links > li > a:hover) { background: rgba(4,107,210,.06); color: var(--ht-blue); }

  :global(.mobile-signup-cta) {
    display: flex; align-items: center; justify-content: center; gap: 8px;
    font-family: var(--ht-font-display); font-size: 1rem; font-weight: 600;
    color: var(--ht-blue); background: rgba(4,107,210,.06);
    padding: 14px 24px; border-radius: 12px;
    margin-top: 20px; transition: all .3s ease;
    border: 1.5px solid rgba(4,107,210,.2);
  }
  :global(.mobile-signup-cta:hover) {
    background: rgba(4,107,210,.12);
    border-color: rgba(4,107,210,.35);
  }

  :global(.mobile-cta) {
    display: block; text-align: center;
    font-family: var(--ht-font-display); font-size: 1rem; font-weight: 600;
    color: #fff; background: var(--ht-blue);
    padding: 14px 24px; border-radius: 12px;
    margin-top: 10px; transition: all .3s ease;
    box-shadow: 0 4px 16px rgba(4,107,210,.3);
  }
  :global(.mobile-cta:hover) { background: var(--ht-blue-dark); }

  /* AI Banner */
  :global(.ai-bar) {
    background: linear-gradient(135deg, var(--ht-navy) 0%, #1e3a5f 100%);
    padding: 11px 0;
    margin-top: 64px;
    position: relative; z-index: 50;
    transition: max-height .4s ease, padding .4s ease, opacity .3s ease;
    overflow: hidden; max-height: 120px;
  }
  :global(.ai-bar.dismissed) {
    max-height: 0; padding: 0; opacity: 0;
    pointer-events: none; margin-top: 0;
  }
  :global(.ai-bar-inner) {
    display: flex; align-items: center; justify-content: center;
    gap: 10px; color: #fff; font-size: .88rem; font-weight: 500;
    font-family: var(--ht-font-display);
  }
  :global(.ai-bar-inner svg) { color: var(--ht-accent); flex-shrink: 0; }
  :global(.ai-bar-link) {
    color: #fff; font-weight: 600; padding: 4px 14px;
    border-radius: 6px; border: 1px solid rgba(255,255,255,.2);
    transition: all .2s; font-size: .84rem; white-space: nowrap;
  }
  :global(.ai-bar-link:hover) { background: rgba(255,255,255,.15); }
  :global(.ai-bar-dismiss) {
    display: flex; align-items: center; justify-content: center;
    color: rgba(255,255,255,.4); cursor: pointer;
    padding: 4px; margin-left: 4px; border-radius: 4px;
    transition: all .2s; background: none; border: none;
    flex-shrink: 0;
  }
  :global(.ai-bar-dismiss:hover) { color: #fff; background: rgba(255,255,255,.1); }

  @media (max-width: 768px) {
    .nav-inner { padding: 0 16px; }
    .nav { height: 56px; }
    .nav-logo img { height: 28px; }
    .nav-links, .nav-actions { display: none; }
    .mobile-actions { display: flex; }
    :global(.ai-bar) { margin-top: 56px; padding: 14px 0 16px; }
    :global(.ai-bar-inner) {
      font-size: .82rem; gap: 8px; text-align: center;
      flex-direction: column; align-items: center;
    }
    :global(.ai-bar-inner > span) { line-height: 1.4; }
    :global(.ai-bar-link) { margin-top: 2px; padding: 7px 18px; font-size: .82rem; }
    :global(.ai-bar-dismiss) {
      position: absolute; top: 8px; right: 12px;
    }
  }
</style>
