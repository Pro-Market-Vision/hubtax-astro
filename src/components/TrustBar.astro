---
const stats = [
  { value: 'AI-Powered', label: 'OCR & Automation' },
  { value: '24/7', label: 'Secure Access' },
  { value: '99.9%', label: 'Uptime Guaranteed' },
  { value: 'SOC 2', label: 'Compliant Security' },
];
---

<section class="trust-bar fade-up">
  <div class="container">
    <div class="trust-stats">
      {stats.map((stat, i) => (
        <>
          <div class="trust-stat">
            <span class="trust-value">{stat.value}</span>
            <span class="trust-label">{stat.label}</span>
          </div>
          {i < stats.length - 1 && <div class="trust-divider"></div>}
        </>
      ))}
    </div>
  </div>
</section>

<style>
  .trust-bar {
    padding: 40px 0;
    background: var(--ht-white);
    border-top: 1px solid rgba(0,0,0,.04);
    border-bottom: 1px solid rgba(0,0,0,.04);
  }
  .trust-stats {
    display: flex; align-items: center; justify-content: center;
    gap: 40px;
  }
  .trust-stat { text-align: center; }
  .trust-value {
    display: block; font-family: var(--ht-font-display);
    font-size: 1.4rem; font-weight: 800; color: var(--ht-navy);
    letter-spacing: -.02em;
  }
  .trust-label {
    display: block; font-size: .78rem; font-weight: 500;
    color: var(--ht-muted); margin-top: 4px;
    text-transform: uppercase; letter-spacing: .06em;
  }
  .trust-divider {
    width: 1px; height: 40px;
    background: rgba(0,0,0,.08);
    flex-shrink: 0;
  }

  @media (max-width: 768px) {
    .trust-stats { gap: 20px; flex-wrap: wrap; }
    .trust-divider { display: none; }
    .trust-stat { flex: 1 1 40%; }
    .trust-value { font-size: 1.2rem; }
  }
</style>
